FROM node:22-bookworm-slim AS builder

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./

ARG VITE_API_BASE_URL=/api
ARG VITE_SENTRY_DSN=
ARG VITE_SENTRY_TRACES_RATE=0.1
ARG VITE_APP_ENV=production

ENV VITE_API_BASE_URL=${VITE_API_BASE_URL} \
    VITE_SENTRY_DSN=${VITE_SENTRY_DSN} \
    VITE_SENTRY_TRACES_RATE=${VITE_SENTRY_TRACES_RATE} \
    VITE_APP_ENV=${VITE_APP_ENV}

RUN npm run build

FROM nginx:1.27-alpine AS runtime

RUN addgroup -g 101 -S nginxapp \
    && adduser -S -D -H -u 101 -G nginxapp nginxapp \
    && mkdir -p /var/cache/nginx /var/run /usr/share/nginx/html \
    && chown -R nginxapp:nginxapp /var/cache/nginx /var/run /usr/share/nginx/html

COPY --from=builder /app/dist /usr/share/nginx/html
COPY infra/nginx/frontend.conf /etc/nginx/conf.d/default.conf

USER nginxapp

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1:8080/healthz >/dev/null || exit 1
