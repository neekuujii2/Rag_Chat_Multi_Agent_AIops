# =============================================================================
# Local development (npm run dev)
# =============================================================================
# Direct to FastAPI on the same machine:
VITE_API_BASE_URL=http://localhost:8000
# Match backend FAISS_SESSION_MAX_AGE_DAYS for banner / retention copy (default 3 if unset or invalid).
# VITE_FAISS_SESSION_MAX_AGE_DAYS=3
# Optional: if the API runs on another port/host:
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# Alternative local setup — same-origin `/api` + Vite proxy (see vite.config.ts):
# VITE_API_BASE_URL=/api
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# =============================================================================
# Vercel production / preview (set in Vercel → Settings → Environment Variables)
# =============================================================================
# Your Coolify public API URL (HTTPS, no trailing slash):
# VITE_API_BASE_URL=https://api.your-domain.com
# VITE_APP_ENV=production
# VITE_SENTRY_DSN=https://...@....ingest....sentry.io/...
# VITE_SENTRY_TRACES_RATE=0.2

# =============================================================================
# Sentry (browser SDK)
# =============================================================================
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_RATE=1.0
