# RAG PDF Chat Backend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Primary API Key (OpenRouter - Recommended)
# =============================================================================
# OpenRouter provides access to multiple models through a single API
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Legacy names still work: OPENAI_API_KEY, OPENAI_API_BASE

# =============================================================================
# Fallback Providers (Optional — each key you add unlocks that provider)
# =============================================================================
# Groq — fast inference on LPU hardware
# Get your key at: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_groq_key_here

# Direct OpenAI API (chat / LLM failover — not used for embeddings unless below is true)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_DIRECT_API_KEY=sk-your_openai_key_here
# Embeddings try cloud providers in order; if all fail, the app falls back to local CPU MiniLM (sentence-transformers, no key).
# Cloud order: OpenRouter → Groq → Gemini → Hugging Face (hub download) → optional OpenAI if EMBEDDING_OPENAI_DIRECT=true.
# EMBEDDING_OPENAI_DIRECT=true

# Google Gemini
# Get your key at: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your_gemini_key_here

# Hugging Face Inference
# Get your key at: https://huggingface.co/settings/tokens
# HF_API_KEY=hf_your_token_here

# =============================================================================
# Application Settings
# =============================================================================
DEFAULT_MODEL=openai/gpt-4o-mini
DEFAULT_PROVIDER=openrouter

# LLM Settings
TEMPERATURE=0.0
MAX_TOKENS=2048

# RAG Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4

# FAISS index persistence directory (relative to backend/); each browser session
# stores under faiss_index/sessions/<uuid>/
FAISS_PERSIST_DIR=faiss_index
# LRU cap for anonymous X-Chat-Session-Id indexes (oldest session folders removed when exceeded)
MAX_VECTOR_SESSIONS=64
# Multi-worker: use 1 worker per API replica (or sticky sessions); otherwise same session_id can race on disk.
# On each API startup: delete session dirs older than N days + non-UUID junk under sessions/. 0 = off.
FAISS_SESSION_MAX_AGE_DAYS=3
# Each value is a separate budget per client IP (from X-Real-IP / X-Forwarded-For), NOT one pool for the whole server.
# Rolling 60-second window; 0 = off. In-memory per API process.
# RATE_LIMIT_UPLOAD_PER_MINUTE: max POST /upload per IP in the last 60s.
# RATE_LIMIT_ASK_PER_MINUTE: max POST /ask + /ask/stream per IP in the last 60s (one count per question).
# Many users on different IPs each get their own budget. One office Wi‑Fi (one public IP) shares one budget.
RATE_LIMIT_UPLOAD_PER_MINUTE=8
RATE_LIMIT_ASK_PER_MINUTE=90
# VPS: mount FAISS_PERSIST_DIR on a volume; set CORS_ORIGINS to your frontend origin(s); keep API keys only in env.
# Have the reverse proxy set X-Real-IP or X-Forwarded-For (first hop = client) so limits apply to real visitors.
# Single worker per replica unless sticky sessions (see MAX_VECTOR_SESSIONS comment).

# =============================================================================
# Sentry (optional — document DSN for ops; tunnel POST /api/oversight needs no secret)
# =============================================================================
# SENTRY_DSN=https://your-key@o123.ingest.sentry.io/456
# SENTRY_ENVIRONMENT=production

# =============================================================================
# CORS (comma-separated browser origins that may call the API)
# =============================================================================
# Local Vite + Vercel production + preview (replace with your real URLs):
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app,https://your-app-git-main.vercel.app
# If unset, defaults to localhost:5173 / :3000 only.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# =============================================================================
# Debug Mode (set to true for development)
# =============================================================================
DEBUG=false
